#!/bin/bash
set -eo pipefail

[[ $# -gt 1 ]] && echo "Usage: $(basename "$0") [--unsupervised]" && exit 1
[[ ! -f /etc/portage/package.declare ]] && echo 'Missing configuration: /etc/portage/package.declare' && exit 1
if [[ ${EUID} -ne 0 ]]; then
  su root -c "$0" "$@"
  exit $?
fi

function is_declared { grep --quiet "^$1$" <<<"${DECLARED_DEPENDENCIES}"; }
function is_installed { grep --quiet "^$1$" <<<"${INSTALLED_DEPENDENCIES}"; }

INSTALLED_DEPENDENCIES=$(cat /var/lib/portage/world)
DECLARED_DEPENDENCIES=$(sed --regexp-extended '/^[[:blank:]]*(#|$)/d; s/#.*//; s/[[:space:]]*$//' </etc/portage/package.declare)
ALL_DEPENDENCIES=$(echo "${INSTALLED_DEPENDENCIES} ${DECLARED_DEPENDENCIES}" | tr ' ' '\n' | sort | uniq)

declare -a INSTALL=()
declare -a REMOVE=()

for DEPENDENCIES in ${ALL_DEPENDENCIES}; do
  if ! is_installed "${DEPENDENCIES}" && is_declared "${DEPENDENCIES}"; then
    INSTALL+=("${DEPENDENCIES}")
  elif is_installed "${DEPENDENCIES}" && ! is_declared "${DEPENDENCIES}"; then
    REMOVE+=("${DEPENDENCIES}")
  fi
done

[[ ${#INSTALL[@]} -ne 0 ]] && emerge --ask="$([[ $1 == '--unsupervised' ]] && echo 'n' || echo 'y')" "${INSTALL[@]}"
[[ ${#REMOVE[@]} -ne 0 ]] && emerge --ask="$([[ $1 == '--unsupervised' ]] && echo 'n' || echo 'y')" --deselect "${REMOVE[@]}"
