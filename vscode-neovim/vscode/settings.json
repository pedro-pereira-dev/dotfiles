{
    // vscode settings
    "editor.accessibilitySupport": "off",
    "files.enableTrash": false,
    "telemetry.telemetryLevel": "off",
    "update.showReleaseNotes": false,
    "window.customTitleBarVisibility": "windowed",
    "window.menuBarVisibility": "toggle",
    "window.newWindowDimensions": "maximized",
    "window.title": "${rootName} ${dirty}",
    "workbench.panel.opensMaximized": "always",
    "workbench.remoteIndicator.showExtensionRecommendations": false,
    "workbench.startupEditor": "none",
    // window settings
    "breadcrumbs.enabled": false,
    "editor.minimap.enabled": false,
    "editor.renderLineHighlightOnlyWhenFocus": true,
    "editor.scrollbar.horizontal": "hidden",
    "editor.scrollbar.vertical": "visible",
    "editor.scrollbar.verticalScrollbarSize": 16,
    "window.commandCenter": false,
    "workbench.editor.decorations.badges": false,
    // explorer settings
    "explorer.compactFolders": false,
    // terminal settings
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.enablePersistentSessions": false,
    "terminal.integrated.shellIntegration.decorationsEnabled": "never",
    // editor text settings
    "editor.fontFamily": "'Hack Nerd Font', 'monospace', monospace",
    "editor.formatOnSave": true,
    "editor.tabSize": 2,
    // editor settings
    "editor.dragAndDrop": false,
    "editor.wordWrap": "on",
    "editor.wrappingIndent": "none",
    "editor.hover.above": false,
    "editor.renderWhitespace": "all",
    "editor.stickyScroll.enabled": false,
    "editor.rulers": [
        80,
        100,
        120
    ],
    // neovim performance
    "extensions.experimental.affinity": {
        "asvetliakov.vscode-neovim": 1
    },
    // theme
    "workbench.iconTheme": "eq-material-theme-icons-darker",
    "workbench.colorTheme": "Tokyo Cat Dark",
    "workbench.colorCustomizations": {
        "[__black__]": {
            "editor.lineHighlightBackground": "#ffffff11"
        }
    },
    // formatter settings
    "[shellscript]": {
        "editor.defaultFormatter": "foxundermoon.shell-format"
    },
    // untracked settings
    "vscode_custom_css.imports": [
        "file://${userHome}/.config/vscode-styles.css"
    ]
}