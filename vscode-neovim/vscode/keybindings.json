[
  {
    "key": "shift+alt+r",
    "command": "extension.multiCommand.execute",
    "args": {
      "sequence": [
        "extension.uninstallCustomCSS",
        "cursorDown",
        "cursorUp",
        "extension.installCustomCSS",
        "cursorDown",
        "cursorUp",
        "workbench.action.reloadWindow"
      ]
    }
  }
]